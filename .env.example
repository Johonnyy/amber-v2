# Amber configuration — copy to `.env` and fill in.
# All values are read by app/config.py (pydantic-settings). Env vars override .env.

# --- Secrets (required) ---
# STT (Whisper) + TTS.
AMBER_OPENAI_API_KEY=sk-...
# The LLM brain (Claude). Required unless AMBER_FEATURE_LLM=false.
AMBER_ANTHROPIC_API_KEY=sk-ant-...

# --- Server ---
AMBER_HOST=0.0.0.0
AMBER_PORT=8000
AMBER_LOG_LEVEL=INFO

# --- Models (swappable; see CLAUDE.md "Config") ---
# Speech-to-text (Whisper).
AMBER_STT_MODEL=whisper-1
# Text-to-speech.
AMBER_TTS_MODEL=tts-1
AMBER_TTS_VOICE=alloy
# Audio container streamed back to the client, per sentence.
# One of: mp3, opus, aac, flac, wav, pcm
AMBER_TTS_FORMAT=mp3
# The "brain" — Claude Haiku. Swappable; route all model choices through config.
AMBER_LLM_MODEL=claude-haiku-4-5-20251001
# Cap on a single spoken reply (tokens). Voice answers are short; keep it modest.
AMBER_LLM_MAX_TOKENS=1024
# The memory writer's fact-extraction model (Phase 3). Off the latency path.
AMBER_MEMORY_MODEL=claude-haiku-4-5-20251001
# Token cap for one fact-extraction call (short JSON list). Keep low.
AMBER_MEMORY_EXTRACT_MAX_TOKENS=512

# --- Memory (Phase 3) ---
# SQLite file holding persistent cross-session knowledge (facts/conversations/tasks).
AMBER_MEMORY_DB_PATH=amber.db
# Hard cap on facts injected into the prompt per turn (memory costs tokens; keep small).
AMBER_MEMORY_MAX_FACTS=12
# Hard cap on new facts kept from a single exchange.
AMBER_MEMORY_MAX_NEW_FACTS=5

# --- Tools (Phase 4) ---
# Max tool-use round trips per turn before Amber must answer with what it has.
AMBER_MAX_TOOL_ITERATIONS=5
# Web search backend: "duckduckgo" (keyless, default) or "tavily" (needs a key).
AMBER_SEARCH_PROVIDER=duckduckgo
# Required only for the tavily provider.
AMBER_SEARCH_API_KEY=
# Cap on result snippets folded into one search result (keep small; costs tokens).
AMBER_SEARCH_MAX_RESULTS=3
AMBER_SEARCH_TIMEOUT_S=10
# OpenClaw bridge — heavy/delegated work over HTTP to your separate OpenClaw host.
# Leave URL empty to disable the bridge (the tool is hidden from the model).
# URL is the host/gateway; TOKEN is sent as `Authorization: Bearer <token>`.
AMBER_OPENCLAW_URL=
AMBER_OPENCLAW_TOKEN=
# OpenClaw work can be slow (browser, multi-step); allow a generous timeout.
AMBER_OPENCLAW_TIMEOUT_S=60

# --- Feature flags ---
# When false, STT is skipped and the canned greeting is returned for any audio.
# Useful to smoke-test the TTS-return half of the pipe without spending STT calls.
AMBER_FEATURE_STT=true
# When false, the LLM brain is bypassed and the Phase-1 canned reply is returned.
# Lets the pipe run end to end without an Anthropic key (tests, demos).
AMBER_FEATURE_LLM=true
# When false, no memory is read into the prompt and no facts are extracted —
# the pipeline behaves exactly as Phase 2 (no DB, no extra LLM calls).
AMBER_FEATURE_MEMORY=true
# When false, the brain never offers tools to the model — it streams a direct
# reply exactly as Phase 2/3 (no tool round trips).
AMBER_FEATURE_TOOLS=true

# --- Auth (Phase 5; off by default) ---
# When set, clients must present this as ?token=... on the WS handshake.
AMBER_AUTH_SECRET=
